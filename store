<!DOCTYPE html>
<html lang="es" class="scroll-smooth">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>THEKNA STORE | Portal B2B de Automatización</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link href="https://fonts.googleapis.com/css2?family=Orbitron:wght@400;500;700;900&family=JetBrains+Mono:wght@100;400;700&family=Outfit:wght@200;400;600;800&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    
    <script src="https://cdnjs.cloudflare.com/ajax/libs/PapaParse/5.3.2/papaparse.min.js"></script>

    <style>
        :root { 
            --at-cyan: #0284c7;
            --bg-light: #f8fafc;
            --text-dark: #0f172a;
        }
        body { 
            font-family: 'Outfit', sans-serif; 
            background-color: var(--bg-light); 
            color: var(--text-dark); 
            overflow-x: hidden;
        }
        .tech-font { font-family: 'Orbitron', sans-serif; }
        .code-font { font-family: 'JetBrains Mono', monospace; }

        #circuit-canvas { position: fixed; top: 0; left: 0; width: 100%; height: 100%; z-index: -1; opacity: 0.4; }

        .data-row {
            background: #ffffff; border: 1px solid rgba(0,0,0,0.05); border-radius: 8px;
            transition: all 0.3s ease; box-shadow: 0 4px 6px rgba(0,0,0,0.02);
        }
        .data-row:hover { border-color: var(--at-cyan); box-shadow: 0 10px 25px rgba(2, 132, 199, 0.15); transform: translateX(4px); }

        .btn-quote {
            background: var(--bg-light); border: 1px solid var(--at-cyan); color: var(--at-cyan);
            padding: 10px 20px; border-radius: 6px; font-family: 'Orbitron', sans-serif; font-size: 10px;
            font-weight: 700; text-transform: uppercase; letter-spacing: 1px; transition: 0.3s;
            cursor: pointer; display: inline-flex; align-items: center; gap: 6px;
        }
        .btn-quote:hover { background: var(--at-cyan); color: #ffffff; box-shadow: 0 8px 15px rgba(2, 132, 199, 0.3); }

        .search-hud {
            background: #ffffff; border: 2px solid rgba(2, 132, 199, 0.3); border-radius: 8px;
            box-shadow: 0 10px 30px rgba(2, 132, 199, 0.1); transition: 0.3s;
        }
        .search-hud:focus-within { border-color: var(--at-cyan); box-shadow: 0 10px 40px rgba(2, 132, 199, 0.2); }

        ::-webkit-scrollbar { width: 8px; }
        ::-webkit-scrollbar-track { background: #e2e8f0; }
        ::-webkit-scrollbar-thumb { background: #94a3b8; border-radius: 10px; }
    </style>
</head>
<body>

    <canvas id="circuit-canvas"></canvas>

    <nav class="fixed top-0 w-full z-[90000] px-8 py-5 flex justify-between items-center bg-white/90 backdrop-blur-xl border-b border-gray-200 shadow-sm">
        <div class="flex items-center gap-4 cursor-pointer" onclick="window.location.href='index.html'">
            <span class="tech-font text-2xl font-black tracking-widest text-slate-800">THEKNA<span class="text-sky-600">STORE</span></span>
            <span class="code-font text-[9px] bg-sky-100 text-sky-700 px-2 py-1 rounded font-bold border border-sky-200">PORTAL B2B</span>
        </div>
        
        <div class="hidden md:flex gap-6 items-center">
            <a href="index.html" class="code-font text-[10px] uppercase tracking-widest text-slate-500 hover:text-sky-600 transition font-bold"><i class="fas fa-arrow-left mr-2"></i> Volver a Thekna Hub</a>
            <a href="https://wa.me/525540431038" target="_blank" class="bg-sky-600 text-white code-font text-[10px] uppercase font-bold px-4 py-2 rounded flex items-center gap-2 hover:bg-slate-900 transition shadow-lg">
                <i class="fab fa-whatsapp text-sm"></i> Soporte de Stock
            </a>
        </div>
    </nav>

    <main class="pt-32 pb-24 px-6 md:px-10 max-w-7xl mx-auto relative z-10">
        
        <div class="mb-10 flex flex-col md:flex-row justify-between items-end gap-6">
            <div>
                <h1 class="tech-font text-4xl md:text-5xl font-black text-slate-900 uppercase tracking-tighter">Inventario <span class="text-sky-600">Industrial</span></h1>
                <p class="text-slate-500 mt-2 font-light max-w-xl leading-relaxed">Acceso directo a más de 8000 números de parte en marcas globales. <strong>Aprovecha el Precio Thekna con 25% de descuento sobre precio de lista.</strong></p>
            </div>
            
            <div class="bg-green-50 border border-green-200 p-4 rounded-lg flex items-center gap-4">
                <div class="bg-green-100 p-3 rounded-full text-green-600 text-xl"><i class="fas fa-tags"></i></div>
                <div>
                    <p class="code-font text-[10px] text-green-700 font-bold tracking-widest uppercase">Estrategia Comercial</p>
                    <p class="tech-font font-black text-slate-800 text-lg">-25% OFF <span class="font-normal text-sm font-sans text-slate-500">sobre lista</span></p>
                </div>
            </div>
        </div>

        <div class="search-hud flex items-center p-2 mb-8 bg-white">
            <i class="fas fa-search text-sky-500 text-xl ml-4 mr-2"></i>
            <input type="text" id="searchInput" placeholder="Buscar por Número de Parte (SKU) o Descripción..." class="flex-1 bg-transparent border-none p-3 text-sm code-font outline-none text-slate-800 placeholder-slate-400">
            <select id="brandFilter" class="bg-slate-50 border border-gray-200 text-slate-600 text-xs code-font p-3 rounded outline-none cursor-pointer hidden md:block">
                <option value="ALL">Todas las Marcas</option>
            </select>
        </div>

        <div id="loading-state" class="text-center py-20">
            <i class="fas fa-circle-notch fa-spin text-4xl text-sky-500 mb-4"></i>
            <p class="code-font text-slate-500 text-sm uppercase tracking-widest">Analizando base de datos local...</p>
        </div>

        <div id="table-header" class="hidden md:grid grid-cols-12 gap-4 px-6 py-3 mb-2 code-font text-[10px] font-bold text-slate-400 uppercase tracking-widest border-b border-gray-200 items-center">
            <div class="col-span-2">Marca</div>
            <div class="col-span-2">No. Parte / SKU</div>
            <div class="col-span-4">Descripción Técnica</div>
            <div class="col-span-2 text-right">Precios (USD)</div>
            <div class="col-span-2 text-right">Acción</div>
        </div>

        <div id="product-list" class="space-y-3">
            </div>

        <div id="empty-state" class="hidden text-center py-20 mt-10">
            </div>
    </main>

    <script>
        const canvas = document.getElementById('circuit-canvas');
        const ctx = canvas.getContext('2d');
        let particles = [];
        function resize() { canvas.width = window.innerWidth; canvas.height = window.innerHeight; }
        window.addEventListener('resize', resize); resize();
        class NodeParticle {
            constructor() {
                this.x = Math.random() * canvas.width; this.y = Math.random() * canvas.height;
                this.vx = (Math.random() - 0.5) * 0.5; this.vy = (Math.random() - 0.5) * 0.5;
                this.size = Math.random() * 2 + 1;
            }
            update() {
                this.x += this.vx; this.y += this.vy;
                if (this.x < 0 || this.x > canvas.width) this.vx *= -1;
                if (this.y < 0 || this.y > canvas.height) this.vy *= -1;
            }
            draw() {
                ctx.beginPath(); ctx.arc(this.x, this.y, this.size, 0, Math.PI * 2);
                ctx.fillStyle = '#cbd5e1'; ctx.fill();
            }
        }
        for (let i = 0; i < 50; i++) particles.push(new NodeParticle());
        function animateCanvas() {
            ctx.clearRect(0, 0, canvas.width, canvas.height);
            particles.forEach(p => { p.update(); p.draw(); });
            requestAnimationFrame(animateCanvas);
        }
        animateCanvas();

        let productsDB = [];
        const DISCOUNT_RATE = 0.25; 
        const productListEl = document.getElementById('product-list');
        const emptyStateEl = document.getElementById('empty-state');
        const loadingStateEl = document.getElementById('loading-state');
        const tableHeader = document.getElementById('table-header');
        const searchInput = document.getElementById('searchInput');
        const brandFilter = document.getElementById('brandFilter');
        const formatMoney = (amount) => new Intl.NumberFormat('en-US', { style: 'currency', currency: 'USD' }).format(amount);

        function renderProducts(products) {
            productListEl.innerHTML = '';
            
            const limit = searchInput.value === '' && brandFilter.value === 'ALL' ? 100 : products.length;
            const itemsToRender = products.slice(0, limit);

            if(itemsToRender.length === 0) {
                emptyStateEl.innerHTML = `<i class="fas fa-box-open text-6xl text-slate-200 mb-4"></i><h3 class="tech-font text-2xl font-bold text-slate-400">Búsqueda sin resultados</h3><p class="text-slate-400 text-sm mt-2">No encontramos ese número de parte.</p>`;
                emptyStateEl.classList.remove('hidden');
                return;
            } else {
                emptyStateEl.classList.add('hidden');
            }

            itemsToRender.forEach(product => {
                const theknaPrice = product.listPrice * (1 - DISCOUNT_RATE);
                const waMessage = encodeURIComponent(`Hola Thekna HUB. Solicito cotización formal de:\n\n*Marca:* ${product.brand}\n*SKU:* ${product.sku}\n*Descripción:* ${product.desc}\n*Precio Thekna Visto:* ${formatMoney(theknaPrice)} USD`);
                const waLink = `https://wa.me/525540431038?text=${waMessage}`;

                const row = document.createElement('div');
                row.className = 'data-row p-4 md:p-5 grid grid-cols-1 md:grid-cols-12 gap-4 items-center relative overflow-hidden';
                row.innerHTML = `
                    <div class="col-span-1 md:col-span-2 flex items-center">
                        <span class="code-font text-[10px] bg-slate-100 text-slate-500 px-2 py-1 rounded font-bold border border-slate-200 uppercase truncate max-w-full">${product.brand}</span>
                    </div>
                    <div class="col-span-1 md:col-span-2">
                        <p class="code-font text-xs text-sky-600 font-bold">${product.sku}</p>
                    </div>
                    <div class="col-span-1 md:col-span-4">
                        <p class="text-sm text-slate-700 font-medium">${product.desc}</p>
                    </div>
                    <div class="col-span-1 md:col-span-2 flex flex-row md:flex-col items-center md:items-end justify-between md:justify-center gap-2 md:gap-0 mt-2 md:mt-0 border-t md:border-t-0 border-gray-100 pt-3 md:pt-0">
                        <div class="flex flex-col text-left md:text-right">
                            <span class="text-[10px] text-slate-400 code-font uppercase">Precio Lista</span>
                            <span class="text-xs text-slate-400 line-through">${formatMoney(product.listPrice)}</span>
                        </div>
                        <div class="flex flex-col text-right">
                            <span class="text-[10px] text-sky-600 font-bold uppercase code-font">PRECIO THEKNA</span>
                            <span class="tech-font text-lg font-black text-slate-900">${formatMoney(theknaPrice)}</span>
                        </div>
                    </div>
                    <div class="col-span-1 md:col-span-2 text-right mt-2 md:mt-0">
                        <a href="${waLink}" target="_blank" class="btn-quote w-full md:w-auto justify-center">
                            <i class="fab fa-whatsapp text-sm"></i> Cotizar
                        </a>
                    </div>
                `;
                productListEl.appendChild(row);
            });
        }

        function filterData() {
            const searchTerm = searchInput.value.toLowerCase();
            const brandTerm = brandFilter.value;
            const filtered = productsDB.filter(p => {
                const matchesSearch = p.sku.toLowerCase().includes(searchTerm) || p.desc.toLowerCase().includes(searchTerm);
                const matchesBrand = brandTerm === 'ALL' || p.brand === brandTerm;
                return matchesSearch && matchesBrand;
            });
            renderProducts(filtered);
        }

        searchInput.addEventListener('input', filterData);
        brandFilter.addEventListener('change', filterData);

        // ALGORITMO AUTO-ESCÁNER A PRUEBA DE ERRORES DE EXCEL
        Papa.parse("stock.csv", {
            download: true,
            header: false, // Leemos por columna, no por nombre exacto
            skipEmptyLines: true,
            complete: function(results) {
                loadingStateEl.classList.add('hidden');
                const rawData = results.data;
                
                // Identificamos dónde empieza la tabla realmente
                let startIndex = 0;
                for(let i=0; i < Math.min(10, rawData.length); i++) {
                    const rowText = rawData[i].join("").toLowerCase();
                    if(rowText.includes("marca") || rowText.includes("sku") || rowText.includes("codigo")) {
                        startIndex = i + 1; // Brincamos el título
                        break;
                    }
                }

                productsDB = [];
                for(let i = startIndex; i < rawData.length; i++) {
                    const row = rawData[i];
                    
                    // Si Excel lo guardó usando punto y coma (;) en lugar de comas
                    let colBrand, colSku, colDesc, colPrice;
                    if (row.length === 1 && row[0].includes(';')) {
                        const splitRow = row[0].split(';');
                        colBrand = splitRow[0]; colSku = splitRow[1]; colDesc = splitRow[2]; colPrice = splitRow[3];
                    } else {
                        colBrand = row[0]; colSku = row[1]; colDesc = row[2]; colPrice = row[3];
                    }

                    const brand = colBrand ? String(colBrand).trim() : "N/A";
                    const sku = colSku ? String(colSku).trim() : "N/A";
                    const desc = colDesc ? String(colDesc).trim() : "Consulte con asesor";
                    const priceStr = colPrice ? String(colPrice) : "0";
                    
                    // Extraemos solo el número del precio
                    const price = parseFloat(priceStr.replace(/[^0-9.-]+/g,""));

                    // Guardamos si hay SKU y el precio es válido
                    if(sku !== "N/A" && sku !== "" && price > 0 && !isNaN(price)) {
                        productsDB.push({ brand, sku, desc, listPrice: price });
                    }
                }

                if(productsDB.length > 0) {
                    tableHeader.classList.remove('hidden');
                    const uniqueBrands = [...new Set(productsDB.map(p => p.brand))];
                    uniqueBrands.sort().forEach(brand => {
                        if(brand && brand !== "N/A") {
                            const option = document.createElement('option');
                            option.value = brand; option.innerText = brand;
                            brandFilter.appendChild(option);
                        }
                    });
                    renderProducts(productsDB);
                } else {
                    emptyStateEl.innerHTML = `<i class="fas fa-exclamation-triangle text-6xl text-orange-400 mb-4"></i><h3 class="tech-font text-2xl font-bold text-slate-800">Formato de Archivo</h3><p class="text-slate-500 mt-2">Abre tu archivo en Excel y guárdalo usando la opción: <b>CSV (delimitado por comas)</b></p>`;
                    emptyStateEl.classList.remove('hidden');
                }
            }
        });
    </script>
</body>
</html>
